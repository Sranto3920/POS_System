# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1

# --- Local MySQL (your Mac) ---
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=pos_inventory_db
DB_PORT=3306

# --- Online MySQL (Render + TiDB Cloud) ---
# Paste in Render dashboard only — do NOT commit real values.
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:4000/pos_inventory_db
# FLASK_ENV=production
# FLASK_DEBUG=0
# MYSQL_SSL=1

# Platform owner (Render: set PLATFORM_OWNER_PASSWORD, then run flask init-db --seed-platform)
PLATFORM_OWNER_EMAIL=owner@posplatform.com
PLATFORM_OWNER_PASSWORD=change-me-strong-password
PLATFORM_OWNER_NAME=Platform Owner
