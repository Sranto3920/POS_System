# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
FLASK_DEBUG=1

# Database (local MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=pos_inventory_db

# Optional: production database URL (Render, Railway, PlanetScale, etc.)
# Overrides DB_* variables when set.
# DATABASE_URL=mysql+pymysql://user:password@host:3306/pos_inventory_db

# Platform owner (only used with: flask init-db --seed-platform)
PLATFORM_OWNER_EMAIL=owner@posplatform.com
PLATFORM_OWNER_PASSWORD=change-me-strong-password
PLATFORM_OWNER_NAME=Platform Owner

# Demo shop users (only used with: flask init-db --seed)
ADMIN_EMAIL=admin@pos.local
ADMIN_PASSWORD=change-me-admin-password
MANAGER_EMAIL=manager@pos.local
MANAGER_PASSWORD=change-me-manager-password
CASHIER_EMAIL=cashier@pos.local
CASHIER_PASSWORD=change-me-cashier-password
